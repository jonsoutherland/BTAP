<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Theme-aware colour palette. Brushes below are defined once and bound to
        their colour keys via {ThemeResource}; the framework swaps the colours
        in/out depending on the root element's ActualTheme (set by
        MainWindow.ApplyThemeFromSettings). Switching theme at runtime updates
        every consumer automatically.

        AccentBrush is the exception: it holds a literal default colour that
        AccentManager mutates at startup and on every settings change, so the
        user's chosen accent stays put regardless of theme.
    -->
    <ResourceDictionary.ThemeDictionaries>

        <!-- ── Default (dark) ──────────────────────────────────────────── -->
        <ResourceDictionary x:Key="Default">
            <Color x:Key="BgPageColor">#FF000000</Color>
            <Color x:Key="BgSurfaceColor">#FF1A2530</Color>
            <Color x:Key="BgElevatedColor">#FF25313C</Color>
            <Color x:Key="BgInputColor">#FF111B22</Color>
            <Color x:Key="BgHoverColor">#FF2C3E4A</Color>
            <Color x:Key="BgSelectedColor">#FF354C5A</Color>

            <Color x:Key="HairlineColor">#8C354C5A</Color>
            <Color x:Key="HairlineStrongColor">#BF506070</Color>

            <Color x:Key="TextPrimaryColor">#FFFFFFFF</Color>
            <Color x:Key="TextDimColor">#FFC0D0D8</Color>
            <Color x:Key="TextMutedColor">#FF869BA5</Color>
            <Color x:Key="TextFaintColor">#FF5B7280</Color>

            <Color x:Key="AccentInkColor">#FFB8DCA7</Color>
            <Color x:Key="AccentDarkColor">#FF0A1410</Color>

            <Color x:Key="StripeAColor">#FF161E26</Color>
            <Color x:Key="StripeBColor">#FF18222A</Color>
            <Color x:Key="DockBgColor">#F20D181F</Color>

            <Color x:Key="TitleClipFillColor">#1AFFFFFF</Color>
        </ResourceDictionary>

        <!-- ── Light ───────────────────────────────────────────────────── -->
        <ResourceDictionary x:Key="Light">
            <!-- Warm off-white surfaces that pair with the sage accent;
                 progressively darker for elevation. BgInput is pure white so
                 input fields stand out clearly against the page. -->
            <Color x:Key="BgPageColor">#FFF7F6F2</Color>
            <Color x:Key="BgSurfaceColor">#FFEDECE5</Color>
            <Color x:Key="BgElevatedColor">#FFFDFCFA</Color>
            <Color x:Key="BgInputColor">#FFFFFFFF</Color>
            <Color x:Key="BgHoverColor">#FFE0DED7</Color>
            <Color x:Key="BgSelectedColor">#FFD3DBC4</Color>

            <!-- Translucent black for hairlines reads as a subtle line on any
                 light fill (vs. picking a single mid-gray that competes with
                 some surfaces and disappears against others). -->
            <Color x:Key="HairlineColor">#25000000</Color>
            <Color x:Key="HairlineStrongColor">#45000000</Color>

            <Color x:Key="TextPrimaryColor">#FF161616</Color>
            <Color x:Key="TextDimColor">#FF333333</Color>
            <Color x:Key="TextMutedColor">#FF6B6B6B</Color>
            <Color x:Key="TextFaintColor">#FF9A9A9A</Color>

            <!-- Accent-derived neutrals flipped for legibility on light bg.
                 AccentInk reads as dark sage on light; AccentDark is now a
                 very light wash so accent-bg surfaces stay readable. -->
            <Color x:Key="AccentInkColor">#FF3E5C2A</Color>
            <Color x:Key="AccentDarkColor">#FFE6F0DC</Color>

            <Color x:Key="StripeAColor">#FFE9E7E0</Color>
            <Color x:Key="StripeBColor">#FFE1DFD9</Color>
            <Color x:Key="DockBgColor">#F2F8F7F2</Color>

            <!-- Title clips use a dark wash on light bg (white wash would
                 vanish on near-white surfaces). -->
            <Color x:Key="TitleClipFillColor">#1A000000</Color>
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

    <!-- ── Theme-invariant colours ──────────────────────────────────────
         Accent + clip-kind hues + video canvas stay constant across themes:
         accent is the user's pick (AccentManager owns it); clip fills are
         alpha-on-anything; the program monitor is always dark because video
         preview readability beats theme uniformity. -->
    <Color x:Key="AccentColor">#FF7FB069</Color>
    <Color x:Key="AccentSoftColor">#2E7FB069</Color>
    <Color x:Key="AccentLineColor">#807FB069</Color>

    <Color x:Key="SageColor">#FF7FB069</Color>
    <Color x:Key="TealMidColor">#FF2C666E</Color>
    <Color x:Key="CoolColor">#FF0F7173</Color>

    <Color x:Key="VideoClipFillColor">#2E7FB069</Color>
    <Color x:Key="AudioClipFillColor">#2E2C666E</Color>
    <Color x:Key="MusicClipFillColor">#2E0F7173</Color>

    <Color x:Key="CanvasBgColor">#FF0A1218</Color>

    <!-- ── Brushes ──────────────────────────────────────────────────────
         Theme-aware brushes bind colour via {ThemeResource} so they refresh
         when the root's ActualTheme changes. Theme-invariant brushes use
         {StaticResource}. -->
    <SolidColorBrush x:Key="BgPageBrush"     Color="{ThemeResource BgPageColor}" />
    <SolidColorBrush x:Key="BgSurfaceBrush"  Color="{ThemeResource BgSurfaceColor}" />
    <SolidColorBrush x:Key="BgElevatedBrush" Color="{ThemeResource BgElevatedColor}" />
    <SolidColorBrush x:Key="BgInputBrush"    Color="{ThemeResource BgInputColor}" />
    <SolidColorBrush x:Key="BgHoverBrush"    Color="{ThemeResource BgHoverColor}" />
    <SolidColorBrush x:Key="BgSelectedBrush" Color="{ThemeResource BgSelectedColor}" />

    <SolidColorBrush x:Key="HairlineBrush"        Color="{ThemeResource HairlineColor}" />
    <SolidColorBrush x:Key="HairlineStrongBrush"  Color="{ThemeResource HairlineStrongColor}" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{ThemeResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextDimBrush"     Color="{ThemeResource TextDimColor}" />
    <SolidColorBrush x:Key="TextMutedBrush"   Color="{ThemeResource TextMutedColor}" />
    <SolidColorBrush x:Key="TextFaintBrush"   Color="{ThemeResource TextFaintColor}" />

    <SolidColorBrush x:Key="AccentInkBrush"   Color="{ThemeResource AccentInkColor}" />
    <SolidColorBrush x:Key="AccentDarkBrush"  Color="{ThemeResource AccentDarkColor}" />

    <SolidColorBrush x:Key="StripeABrush"     Color="{ThemeResource StripeAColor}" />
    <SolidColorBrush x:Key="StripeBBrush"     Color="{ThemeResource StripeBColor}" />
    <SolidColorBrush x:Key="DockBgBrush"      Color="{ThemeResource DockBgColor}" />

    <SolidColorBrush x:Key="TitleClipFillBrush" Color="{ThemeResource TitleClipFillColor}" />

    <!-- Accent: literal default colour, mutated at runtime by AccentManager
         based on AppSettings.Accent / CustomAccentHex. NOT theme-aware — the
         user's accent shouldn't shift between themes. -->
    <SolidColorBrush x:Key="AccentBrush"      Color="#FF7FB069" />
    <SolidColorBrush x:Key="AccentSoftBrush"  Color="#2E7FB069" />
    <SolidColorBrush x:Key="AccentLineBrush"  Color="#807FB069" />

    <SolidColorBrush x:Key="SageBrush"     Color="{StaticResource SageColor}" />
    <SolidColorBrush x:Key="TealMidBrush"  Color="{StaticResource TealMidColor}" />
    <SolidColorBrush x:Key="CoolBrush"     Color="{StaticResource CoolColor}" />

    <SolidColorBrush x:Key="VideoClipFillBrush" Color="{StaticResource VideoClipFillColor}" />
    <SolidColorBrush x:Key="AudioClipFillBrush" Color="{StaticResource AudioClipFillColor}" />
    <SolidColorBrush x:Key="MusicClipFillBrush" Color="{StaticResource MusicClipFillColor}" />

    <SolidColorBrush x:Key="CanvasBgBrush" Color="{StaticResource CanvasBgColor}" />

    <!-- Transparent brush sentinel -->
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent" />

    <!-- ── Typography ───────────────────────────────────────────────── -->
    <FontFamily x:Key="SansFont">Geist, Segoe UI Variable Display, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="SerifFont">Instrument Serif, Georgia, serif</FontFamily>
    <FontFamily x:Key="MonoFont">JetBrains Mono, Cascadia Mono, Consolas, monospace</FontFamily>

    <!-- Corner radii -->
    <CornerRadius x:Key="RadiusSm">4</CornerRadius>
    <CornerRadius x:Key="RadiusMd">6</CornerRadius>
    <CornerRadius x:Key="RadiusLg">10</CornerRadius>
    <CornerRadius x:Key="RadiusXl">14</CornerRadius>
    <CornerRadius x:Key="RadiusFull">999</CornerRadius>

</ResourceDictionary>
