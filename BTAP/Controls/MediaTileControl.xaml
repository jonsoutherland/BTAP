<UserControl
    x:Class="BTAP.Controls.MediaTileControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{StaticResource BgSurfaceBrush}"
            BorderBrush="{StaticResource HairlineBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusMd}"
            CanDrag="True"
            DragStarting="OnDragStarting">
        <Grid RowDefinitions="72,Auto">

            <!-- Thumbnail area -->
            <Border Grid.Row="0" CornerRadius="5,5,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#4D1A3040" Offset="0"/>
                        <GradientStop Color="#4D0A1218" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <TextBlock x:Name="TypeIconText" FontFamily="Segoe MDL2 Assets" FontSize="20"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{StaticResource TextMutedBrush}" Opacity="0.5" />
                    <Border VerticalAlignment="Bottom" HorizontalAlignment="Left"
                            Margin="6" Padding="3,1" CornerRadius="3"
                            Background="#CC0A1218">
                        <TextBlock x:Name="DurationText"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="9" Foreground="{StaticResource TextDimBrush}" />
                    </Border>
                    <Border VerticalAlignment="Top" HorizontalAlignment="Right"
                            Margin="6" Padding="3,1" CornerRadius="3"
                            Background="#880A1218">
                        <TextBlock x:Name="TypeText"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="8" CharacterSpacing="60"
                                   Foreground="{StaticResource TextFaintBrush}" />
                    </Border>
                </Grid>
            </Border>

            <!-- Name -->
            <Border Grid.Row="1" Padding="8,6,8,8"
                    BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="0,1,0,0">
                <TextBlock x:Name="NameText" FontSize="10.5" FontWeight="Medium"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="2" TextWrapping="Wrap" />
            </Border>
        </Grid>
    </Border>
</UserControl>
