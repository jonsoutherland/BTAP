<UserControl
    x:Class="BTAP.Controls.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:BTAP.Controls">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Section header ─────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,18">
            <TextBlock Text="Today · Application settings"
                       FontSize="11" CharacterSpacing="140"
                       Foreground="{StaticResource TextFaintBrush}" />
            <TextBlock FontSize="40" FontFamily="{StaticResource SerifFont}"
                       FontStyle="Italic" LineHeight="44"
                       Foreground="{StaticResource TextPrimaryBrush}">
                <Run Text="Make it yours. " /><Run Text="Tune display, shortcuts, export, layout."
                                                  Foreground="{StaticResource TextMutedBrush}" />
            </TextBlock>
        </StackPanel>

        <!-- ── Tabs ────────────────────────────────────────────────────── -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*">
            <Border Grid.Row="0" BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="0,0,0,1" Padding="0,0,0,6">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <Button x:Name="TabDisplay"  Content="Display"        Tag="display"
                            Style="{StaticResource GhostButtonStyle}" Padding="14,8" FontSize="12"
                            FontWeight="Medium" Click="OnTabClick"
                            Background="{StaticResource BgElevatedBrush}"
                            Foreground="{StaticResource TextPrimaryBrush}" />
                    <Button x:Name="TabKeybinds" Content="Keybinds"       Tag="keys"
                            Style="{StaticResource GhostButtonStyle}" Padding="14,8" FontSize="12"
                            FontWeight="Medium" Click="OnTabClick" />
                    <Button x:Name="TabExport"   Content="Export"         Tag="export"
                            Style="{StaticResource GhostButtonStyle}" Padding="14,8" FontSize="12"
                            FontWeight="Medium" Click="OnTabClick" />
                    <Button x:Name="TabLayout"   Content="Layout"         Tag="layout"
                            Style="{StaticResource GhostButtonStyle}" Padding="14,8" FontSize="12"
                            FontWeight="Medium" Click="OnTabClick" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" Padding="0,20,0,8">

                <!-- ══ Display ══════════════════════════════════════════════ -->
                <ScrollViewer x:Name="PanelDisplay" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="22" MaxWidth="720" HorizontalAlignment="Left">

                        <StackPanel Spacing="6">
                            <TextBlock Text="THEME" Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="Choose how BTAP appears. System follows your Windows preference."
                                       FontSize="11.5" Foreground="{StaticResource TextFaintBrush}" />
                            <ComboBox x:Name="CbTheme" Width="260" Margin="0,4,0,0"
                                      SelectionChanged="OnThemeChanged">
                                <ComboBoxItem Content="System default" Tag="System" />
                                <ComboBoxItem Content="Dark"           Tag="Dark" />
                                <ComboBoxItem Content="Light"          Tag="Light" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="ACCENT" Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="Highlight color used by primary buttons and selection."
                                       FontSize="11.5" Foreground="{StaticResource TextFaintBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,4,0,0">
                                <Button x:Name="AccentSage"   Tag="Sage"   Click="OnAccentClick"
                                        Style="{StaticResource GhostButtonStyle}" Padding="0">
                                    <Border Width="32" Height="32" CornerRadius="16"
                                            Background="#FF7FB069" BorderBrush="{StaticResource HairlineBrush}"
                                            BorderThickness="1" />
                                </Button>
                                <Button x:Name="AccentBlue"   Tag="Blue"   Click="OnAccentClick"
                                        Style="{StaticResource GhostButtonStyle}" Padding="0">
                                    <Border Width="32" Height="32" CornerRadius="16"
                                            Background="#FF5B9FE3" BorderBrush="{StaticResource HairlineBrush}"
                                            BorderThickness="1" />
                                </Button>
                                <Button x:Name="AccentPurple" Tag="Purple" Click="OnAccentClick"
                                        Style="{StaticResource GhostButtonStyle}" Padding="0">
                                    <Border Width="32" Height="32" CornerRadius="16"
                                            Background="#FFA67FE0" BorderBrush="{StaticResource HairlineBrush}"
                                            BorderThickness="1" />
                                </Button>
                                <Button x:Name="AccentAmber"  Tag="Amber"  Click="OnAccentClick"
                                        Style="{StaticResource GhostButtonStyle}" Padding="0">
                                    <Border Width="32" Height="32" CornerRadius="16"
                                            Background="#FFE0A352" BorderBrush="{StaticResource HairlineBrush}"
                                            BorderThickness="1" />
                                </Button>
                                <Button x:Name="AccentRose"   Tag="Rose"   Click="OnAccentClick"
                                        Style="{StaticResource GhostButtonStyle}" Padding="0">
                                    <Border Width="32" Height="32" CornerRadius="16"
                                            Background="#FFD27FA8" BorderBrush="{StaticResource HairlineBrush}"
                                            BorderThickness="1" />
                                </Button>
                                <Button x:Name="AccentTeal"   Tag="Teal"   Click="OnAccentClick"
                                        Style="{StaticResource GhostButtonStyle}" Padding="0">
                                    <Border Width="32" Height="32" CornerRadius="16"
                                            Background="#FF5BB8B0" BorderBrush="{StaticResource HairlineBrush}"
                                            BorderThickness="1" />
                                </Button>
                                <Button x:Name="AccentCoral"  Tag="Coral"  Click="OnAccentClick"
                                        Style="{StaticResource GhostButtonStyle}" Padding="0">
                                    <Border Width="32" Height="32" CornerRadius="16"
                                            Background="#FFE08070" BorderBrush="{StaticResource HairlineBrush}"
                                            BorderThickness="1" />
                                </Button>
                                <Button x:Name="AccentSlate"  Tag="Slate"  Click="OnAccentClick"
                                        Style="{StaticResource GhostButtonStyle}" Padding="0">
                                    <Border Width="32" Height="32" CornerRadius="16"
                                            Background="#FF8090A8" BorderBrush="{StaticResource HairlineBrush}"
                                            BorderThickness="1" />
                                </Button>
                                <TextBlock x:Name="TbAccentLabel" VerticalAlignment="Center"
                                           Margin="6,0,0,0" FontSize="11.5"
                                           Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,6,0,0"
                                        VerticalAlignment="Center">
                                <CheckBox x:Name="CbUseCustomAccent"
                                          Content="Custom color"
                                          Checked="OnUseCustomAccentChanged"
                                          Unchecked="OnUseCustomAccentChanged" />
                                <Border x:Name="CustomAccentSwatch" Width="32" Height="32"
                                        CornerRadius="16"
                                        BorderBrush="{StaticResource HairlineBrush}"
                                        BorderThickness="1" />
                                <TextBox x:Name="TbCustomAccentHex"
                                         Width="120"
                                         FontFamily="{StaticResource MonoFont}" FontSize="11"
                                         PlaceholderText="#7FB069"
                                         LostFocus="OnCustomAccentHexChanged"
                                         KeyDown="OnCustomAccentHexKeyDown" />
                                <Button Content="Pick…" Style="{StaticResource GhostButtonStyle}"
                                        Padding="10,4" FontSize="11.5"
                                        Click="OnPickCustomAccent" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="DEFAULT TRACK COLORS" Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="Default fill used for clips on each kind of track. Right-click any track in the editor to override per track."
                                       FontSize="11.5" Foreground="{StaticResource TextFaintBrush}" TextWrapping="Wrap" />
                            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto"
                                  ColumnSpacing="14" RowSpacing="8" Margin="0,6,0,0">
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                    <Border x:Name="SwatchVideoClip" Width="22" Height="22"
                                            CornerRadius="11"
                                            BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1" />
                                    <Button Content="Video" Style="{StaticResource GhostButtonStyle}"
                                            Padding="8,4" FontSize="11" Tag="Video"
                                            Click="OnPickDefaultClipColor" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <Border x:Name="SwatchAudioClip" Width="22" Height="22"
                                            CornerRadius="11"
                                            BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1" />
                                    <Button Content="Audio" Style="{StaticResource GhostButtonStyle}"
                                            Padding="8,4" FontSize="11" Tag="Audio"
                                            Click="OnPickDefaultClipColor" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                    <Border x:Name="SwatchMusicClip" Width="22" Height="22"
                                            CornerRadius="11"
                                            BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1" />
                                    <Button Content="Music" Style="{StaticResource GhostButtonStyle}"
                                            Padding="8,4" FontSize="11" Tag="Music"
                                            Click="OnPickDefaultClipColor" />
                                </StackPanel>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8">
                                    <Border x:Name="SwatchTitleClip" Width="22" Height="22"
                                            CornerRadius="11"
                                            BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1" />
                                    <Button Content="Title" Style="{StaticResource GhostButtonStyle}"
                                            Padding="8,4" FontSize="11" Tag="Title"
                                            Click="OnPickDefaultClipColor" />
                                </StackPanel>
                            </Grid>
                            <Button Content="Reset clip colors"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Padding="10,4" FontSize="11"
                                    HorizontalAlignment="Left" Margin="0,4,0,0"
                                    Click="OnResetDefaultClipColors" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="DENSITY" Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="Compact tightens padding for smaller screens."
                                       FontSize="11.5" Foreground="{StaticResource TextFaintBrush}" />
                            <ComboBox x:Name="CbDensity" Width="260" Margin="0,4,0,0"
                                      SelectionChanged="OnDensityChanged">
                                <ComboBoxItem Content="Comfortable" Tag="Comfortable" />
                                <ComboBoxItem Content="Compact"     Tag="Compact" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="OPTIONS" Style="{StaticResource SectionLabelStyle}" />
                            <CheckBox x:Name="CbShowThumbnails" Content="Show project thumbnails on home"
                                      Margin="0,4,0,0" Checked="OnShowThumbnailsChanged"
                                      Unchecked="OnShowThumbnailsChanged" />
                            <CheckBox x:Name="CbReducedMotion" Content="Reduce motion (disable transitions)"
                                      Checked="OnReducedMotionChanged" Unchecked="OnReducedMotionChanged" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="ONBOARDING" Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="Replay the first-run intro to repick your layout, color, theme, and default folders."
                                       FontSize="11.5" Foreground="{StaticResource TextFaintBrush}" TextWrapping="Wrap" />
                            <Button Content="Replay onboarding"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Padding="14,6" FontSize="11"
                                    HorizontalAlignment="Left" Margin="0,4,0,0"
                                    Click="OnReplayOnboardingClick" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- ══ Keybinds ═════════════════════════════════════════════ -->
                <Grid x:Name="PanelKeybinds" Visibility="Collapsed">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <TextBlock Grid.Row="0"
                                   Text="Same keyboard customizer used in the editor — changes save instantly and apply everywhere. Scroll horizontally if the keyboard exceeds the window width."
                                   FontSize="11.5" Foreground="{StaticResource TextFaintBrush}"
                                   Margin="0,0,0,12" TextWrapping="Wrap" />

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10"
                                    Margin="0,0,0,12" VerticalAlignment="Center">
                            <TextBlock Text="PRESET" Style="{StaticResource SectionLabelStyle}"
                                       VerticalAlignment="Center" />
                            <ComboBox x:Name="CbKeybindPreset" Width="200"
                                      SelectionChanged="OnKeybindPresetChanged">
                                <ComboBoxItem Content="Minimal"        Tag="Minimal" />
                                <ComboBoxItem Content="Default (BTAP)" Tag="Default" />
                                <ComboBoxItem Content="Premiere-like"  Tag="PremiereLike" />
                            </ComboBox>
                            <TextBlock Text="Switching presets replaces every binding below. Your manual edits survive until the next preset switch."
                                       FontSize="11" TextWrapping="Wrap" MaxWidth="380"
                                       Foreground="{StaticResource TextFaintBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <ScrollViewer Grid.Row="2"
                                      HorizontalScrollBarVisibility="Auto"
                                      HorizontalScrollMode="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      VerticalScrollMode="Auto">
                            <Border Background="{StaticResource BgSurfaceBrush}"
                                    BorderBrush="{StaticResource HairlineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusLg}"
                                    Padding="2"
                                    HorizontalAlignment="Left">
                                <controls:KeyboardCustomizerControl x:Name="KeyboardCustomizer" />
                            </Border>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <!-- ══ Export ═══════════════════════════════════════════════ -->
                <ScrollViewer x:Name="PanelExport" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="22" MaxWidth="720" HorizontalAlignment="Left">

                        <StackPanel Spacing="6">
                            <TextBlock Text="FORMAT" Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="Default container and codecs for Export dialog."
                                       FontSize="11.5" Foreground="{StaticResource TextFaintBrush}" />
                            <ComboBox x:Name="CbContainer" Width="260" Margin="0,4,0,0"
                                      SelectionChanged="OnContainerChanged">
                                <ComboBoxItem Content="MP4 · H.264 + AAC" Tag="Mp4H264Aac" />
                                <ComboBoxItem Content="MP4 · H.265 + AAC" Tag="Mp4H265Aac" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="VIDEO BITRATE" Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="Average target bitrate (Kbps). Higher = better quality, larger files."
                                       FontSize="11.5" Foreground="{StaticResource TextFaintBrush}" />
                            <NumberBox x:Name="NbBitrate" Width="260" Margin="0,4,0,0"
                                       Minimum="300" Maximum="200000" SmallChange="500" LargeChange="2000"
                                       SpinButtonPlacementMode="Inline"
                                       ValueChanged="OnBitrateChanged" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="FRAME RATE" Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="Default output frame rate when project doesn't override."
                                       FontSize="11.5" Foreground="{StaticResource TextFaintBrush}" />
                            <NumberBox x:Name="NbFps" Width="260" Margin="0,4,0,0"
                                       Minimum="15" Maximum="120" SmallChange="1" LargeChange="6"
                                       SpinButtonPlacementMode="Inline"
                                       ValueChanged="OnFpsChanged" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="FILE SIZE LIMIT" Style="{StaticResource SectionLabelStyle}" />
                            <CheckBox x:Name="CbLimitSize" Content="Enable by default"
                                      Margin="0,4,0,0" Checked="OnLimitSizeChanged" Unchecked="OnLimitSizeChanged" />
                            <NumberBox x:Name="NbMaxSize" Width="260"
                                       Header="Max size (MB)"
                                       Minimum="1" Maximum="100000" SmallChange="10" LargeChange="100"
                                       SpinButtonPlacementMode="Inline"
                                       ValueChanged="OnMaxSizeChanged" />
                        </StackPanel>

                        <Button Content="Reset export defaults"
                                Style="{StaticResource BtapButtonStyle}"
                                Click="OnResetExportClick"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </ScrollViewer>

                <!-- ══ Layout ═══════════════════════════════════════════════ -->
                <Grid x:Name="PanelLayout" Visibility="Collapsed" RowDefinitions="Auto,Auto,*,Auto"
                      RowSpacing="14">

                    <TextBlock Grid.Row="0"
                               Text="The preview below behaves exactly like the live editor. Drag panel headers to rearrange, drag splitters to resize. Use Edit at full size for a roomier canvas."
                               FontSize="11.5" Foreground="{StaticResource TextFaintBrush}"
                               TextWrapping="Wrap" />

                    <!-- Preset chips + visibility toggles + full-size editor -->
                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="14">
                        <StackPanel Grid.Column="0" Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="BtnPresetSimple"    Tag="Simple"   Click="OnPresetClick"
                                        Style="{StaticResource GhostButtonStyle}" Padding="14,8" FontSize="11.5">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Simple" FontWeight="Medium" FontSize="12" />
                                        <TextBlock Text="Clipchamp-like" FontSize="10"
                                                   Foreground="{StaticResource TextFaintBrush}" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="BtnPresetModerate"  Tag="Moderate" Click="OnPresetClick"
                                        Style="{StaticResource GhostButtonStyle}" Padding="14,8" FontSize="11.5">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Moderate" FontWeight="Medium" FontSize="12" />
                                        <TextBlock Text="Three-pane editor" FontSize="10"
                                                   Foreground="{StaticResource TextFaintBrush}" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="BtnPresetComplex"   Tag="Complex"  Click="OnPresetClick"
                                        Style="{StaticResource GhostButtonStyle}" Padding="14,8" FontSize="11.5">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Complex" FontWeight="Medium" FontSize="12" />
                                        <TextBlock Text="Premiere-like" FontSize="10"
                                                   Foreground="{StaticResource TextFaintBrush}" />
                                    </StackPanel>
                                </Button>
                                <TextBlock x:Name="TbPresetLabel" VerticalAlignment="Center"
                                           Margin="6,0,0,0" FontSize="11.5"
                                           Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <CheckBox x:Name="CbShowLibrary"   Content="Show library"
                                          Checked="OnLayoutToggleChanged" Unchecked="OnLayoutToggleChanged" />
                                <CheckBox x:Name="CbShowInspector" Content="Show inspector"
                                          Checked="OnLayoutToggleChanged" Unchecked="OnLayoutToggleChanged" />
                                <Button x:Name="BtnResetToPreset" Content="Reset to preset"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Padding="10,4" FontSize="11"
                                        Click="OnResetToPresetClick" />
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" x:Name="BtnFullsizeEdit"
                                Style="{StaticResource BtapButtonStyle}"
                                Padding="14,8" FontSize="11.5"
                                VerticalAlignment="Top"
                                Click="OnFullsizeEditClick">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE740;" FontSize="11" />
                                <TextBlock Text="Edit at full size" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Live preview — same DockHost the editor uses, but with
                         sample-content placeholders so the user can rearrange
                         without a project loaded. -->
                    <Border Grid.Row="2"
                            Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource HairlineBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusLg}"
                            Padding="2"
                            MinHeight="420">
                        <controls:LayoutPreviewView x:Name="LayoutPreview" />
                    </Border>

                    <TextBlock Grid.Row="3"
                               Text="Drag any panel header onto another panel — drop on its top, bottom, left, or right edge to dock there. Drag splitters to resize. Esc cancels an in-progress drag."
                               FontSize="11" Foreground="{StaticResource TextFaintBrush}"
                               TextWrapping="Wrap" />
                </Grid>

            </Grid>
        </Grid>

    <!-- ══ Fullsize layout editor overlay ════════════════════════════════
         Lives inside the root Grid because a UserControl can only have one
         root element, but a Popup renders over the XamlRoot regardless of
         where it sits in the tree, so this doesn't affect layout. Opened by
         the "Edit at full size" button; Esc / Close dismiss. -->
    <Popup x:Name="FullsizePopup" IsLightDismissEnabled="False">
        <Grid x:Name="FullsizePopupRoot"
              Background="{StaticResource BgPageBrush}">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0"
                        Background="{StaticResource BgPageBrush}"
                        BorderBrush="{StaticResource HairlineBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="14,8">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Grid.Column="0" Text="Layout editor · full size"
                                   FontSize="12" FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="Drag panels to dock; Esc to close."
                                   FontSize="11"
                                   Foreground="{StaticResource TextFaintBrush}"
                                   VerticalAlignment="Center"
                                   Margin="14,0,0,0" />
                        <Button Grid.Column="2" Content="Close"
                                Style="{StaticResource BtapButtonStyle}"
                                Padding="14,4" FontSize="11"
                                Click="OnFullsizeEditClose" />
                    </Grid>
                </Border>
                <controls:LayoutPreviewView Grid.Row="1" x:Name="LayoutPreviewFull" />
            </Grid>
        </Grid>
    </Popup>
    </Grid>
</UserControl>
