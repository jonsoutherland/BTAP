<Page
    x:Class="BTAP.Pages.OnboardingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:BTAP.Controls"
    Background="{ThemeResource BgPageColor}"
    KeyDown="OnPageKeyDown"
    IsTabStop="True">

    <Grid x:Name="RootGrid">
        <!-- Plain page background. We previously had a timecode-ruler / marble
             ambient layer here, but the recurring rulers felt noisy across the
             screen — the steps' own animations carry enough motion on their
             own. -->

        <!-- Content layer -->
        <Grid Padding="48,32,48,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Top chrome: wordmark left, skip right -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <Border Width="18" Height="18" CornerRadius="3"
                            Background="Transparent">
                        <TextBlock Text="▶" FontSize="10"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="BTAP" FontWeight="Medium" FontSize="12"
                               Foreground="{ThemeResource TextPrimaryColor}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="— setup" FontSize="12" FontStyle="Italic"
                               FontFamily="{StaticResource SerifFont}"
                               Foreground="{ThemeResource TextFaintColor}"
                               VerticalAlignment="Center"
                               Margin="2,0,0,0" />
                    <!-- BUILD MARKER: confirms which build is running.
                         Hover for the animation-debug log path. -->
                    <Border Background="{StaticResource AccentBrush}"
                            CornerRadius="3"
                            Padding="6,2"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            ToolTipService.ToolTip="Anim log: %TEMP%\btap-anim.log">
                        <TextBlock Text="anim-v26"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="10"
                                   Foreground="{ThemeResource TextPrimaryColor}" />
                    </Border>
                </StackPanel>

                <Button Grid.Column="1" x:Name="BtnSkip"
                        Style="{StaticResource GhostButtonStyle}"
                        Padding="10,4" FontSize="11"
                        Click="OnSkipClick">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Skip setup" />
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE76C;" FontSize="10" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Step host — two ContentPresenters layered so an outgoing step
                 can animate out while the incoming step animates in. The
                 SpliceBar overlays both during transitions, sweeping across
                 the page as an accent-coloured film cut. Code attaches
                 TranslateTransforms + Storyboards at runtime. -->
            <Grid x:Name="StepHostContainer" Grid.Row="1" Margin="0,16,0,16">
                <!-- ContentThemeTransition with a large HorizontalOffset gives
                     each step a dramatic slide-in. Combined with the opaque
                     Background on every IOnboardingStep UserControl, the
                     incoming step's solid bg covers the old content with a
                     hard edge — that's the "push wipe" effect: the new
                     content's leading edge IS the wipe line. We use
                     ContentThemeTransition rather than a custom Composition
                     panel because it's the only animation primitive
                     confirmed to render in this environment. -->
                <ContentControl x:Name="StepHost"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch">
                    <ContentControl.ContentTransitions>
                        <TransitionCollection>
                            <!-- VerticalOffset must be explicitly 0 — the
                                 default is ~28 px, which combined with a
                                 large HorizontalOffset makes the slide read
                                 as diagonal. -->
                            <ContentThemeTransition HorizontalOffset="600"
                                                    VerticalOffset="0" />
                        </TransitionCollection>
                    </ContentControl.ContentTransitions>
                </ContentControl>
            </Grid>

            <!-- Bottom chrome: back button + progress dots -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" x:Name="BtnBack"
                        HorizontalAlignment="Left"
                        Style="{StaticResource GhostButtonStyle}"
                        Padding="10,4" FontSize="11"
                        Visibility="Collapsed"
                        Click="OnBackClick">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72B;" FontSize="10" />
                        <TextBlock Text="Back" />
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="1" x:Name="ProgressDots"
                            Orientation="Horizontal" Spacing="8"
                            HorizontalAlignment="Center" />
            </Grid>
        </Grid>

    </Grid>
</Page>
