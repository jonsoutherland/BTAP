<UserControl
    x:Class="BTAP.Pages.Onboarding.WelcomeStep"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
    Background="{ThemeResource BgPageColor}">

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Spacing="20" MaxWidth="640" HorizontalAlignment="Center">

            <!-- Wordmark — large serif italic with characterspacing that
                 tightens during the entrance storyboard. -->
            <TextBlock x:Name="Wordmark"
                       Text="BTAP"
                       FontSize="92"
                       FontFamily="{StaticResource SerifFont}"
                       FontStyle="Italic"
                       FontWeight="Medium"
                       CharacterSpacing="200"
                       Foreground="{ThemeResource TextPrimaryColor}"
                       HorizontalAlignment="Center">
                <TextBlock.RenderTransform>
                    <ScaleTransform x:Name="WordmarkScale" ScaleX="1.2" ScaleY="1.2"
                                    CenterX="0" CenterY="0" />
                </TextBlock.RenderTransform>
                <TextBlock.RenderTransformOrigin>0.5,0.5</TextBlock.RenderTransformOrigin>
            </TextBlock>

            <TextBlock x:Name="Tagline"
                       Text="A film editor that wants to know you a little."
                       FontSize="16"
                       FontStyle="Italic"
                       FontFamily="{StaticResource SerifFont}"
                       Foreground="{ThemeResource TextMutedColor}"
                       HorizontalAlignment="Center"
                       Opacity="0" />

            <TextBlock x:Name="Subline"
                       Text="This is the only data we will ever collect from you."
                       FontSize="11.5"
                       FontFamily="{StaticResource MonoFont}"
                       Foreground="{ThemeResource TextFaintColor}"
                       CharacterSpacing="80"
                       HorizontalAlignment="Center"
                       Opacity="0"
                       Margin="0,2,0,0" />

            <Button x:Name="BtnStart"
                    Content="Let's set you up"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Padding="20,10" FontSize="13"
                    Margin="0,18,0,0"
                    HorizontalAlignment="Center"
                    Click="OnStartClick"
                    Opacity="0">
                <Button.RenderTransform>
                    <TranslateTransform x:Name="BtnTx" Y="14" />
                </Button.RenderTransform>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
