<Page
    x:Class="BTAP.Pages.LandingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BTAP.Pages"
    xmlns:vm="using:BTAP.ViewModels"
    xmlns:models="using:BTAP.Models"
    xmlns:controls="using:BTAP.Controls"
    Background="{StaticResource BgPageBrush}">

    <Page.Resources>
        <DataTemplate x:Key="RecentCardTemplate" x:DataType="models:RecentProject">
            <Button Click="OnOpenRecentProject"
                    Tag="{x:Bind}"
                    Style="{StaticResource GhostButtonStyle}"
                    Padding="0" HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch">
                <Border Background="{StaticResource BgSurfaceBrush}"
                        BorderBrush="{StaticResource HairlineBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusLg}"
                       >
                    <Grid RowDefinitions="Auto,Auto">
                        <!-- Thumbnail -->
                        <Border Grid.Row="0" Height="120">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#4D1A2530" Offset="0"/>
                                    <GradientStop Color="#4D0A1218" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <!-- Duration badge -->
                            <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                    Margin="8" Padding="3,1"
                                    Background="#CC0A1218"
                                    CornerRadius="3">
                                <TextBlock Text="{x:Bind Duration}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="10" Foreground="{StaticResource TextDimBrush}" />
                            </Border>
                        </Border>

                        <!-- Info -->
                        <StackPanel Grid.Row="1" Padding="12,10,12,12" Spacing="4">
                            <TextBlock Text="{x:Bind Name}"
                                       FontSize="13" FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis" />
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="{x:Bind LastEdited}"
                                           FontSize="11" Foreground="{StaticResource TextFaintBrush}" />
                                <TextBlock Grid.Column="1" Text="{x:Bind Spec}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="10" Foreground="{StaticResource TextFaintBrush}" />
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
            </Button>
        </DataTemplate>
    </Page.Resources>

    <Grid ColumnDefinitions="220,*">

        <!-- ── Sidebar ─────────────────────────────────────────────── -->
        <Border Grid.Column="0"
                Background="{StaticResource BgPageBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,0,1,0">
            <StackPanel Padding="16,24,16,24" Spacing="2">

                <!-- Logo -->
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="8,0,8,14">
                    <Border Width="22" Height="22" CornerRadius="5"
                            Background="{StaticResource AccentBrush}">
                        <TextBlock Text="▶" FontSize="10" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Foreground="{StaticResource AccentDarkBrush}" />
                    </Border>
                    <TextBlock Text="BTAP" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                    <Border Margin="4,0,0,0" Padding="4,1" CornerRadius="10"
                            Background="{StaticResource BgElevatedBrush}"
                            BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1"
                            VerticalAlignment="Center">
                        <TextBlock Text="2.4.0" FontFamily="{StaticResource MonoFont}"
                                   FontSize="9" Foreground="{StaticResource TextFaintBrush}" />
                    </Border>
                </StackPanel>

                <!-- Nav items -->
                <Button x:Name="BtnRecent" Content="Recent" Tag="recent"
                        Style="{StaticResource GhostButtonStyle}"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="10,7" Click="OnNavTabClick"
                        Background="{StaticResource BgElevatedBrush}"
                        Foreground="{StaticResource TextPrimaryBrush}" />
                <Button x:Name="BtnTemplates" Content="New from template" Tag="templates"
                        Style="{StaticResource GhostButtonStyle}"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="10,7" Click="OnNavTabClick" />
                <Button x:Name="BtnSettings" Content="Settings" Tag="settings"
                        Style="{StaticResource GhostButtonStyle}"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="10,7" Click="OnNavTabClick" />

                <!-- Spacer -->
                <Border Height="1" Background="{StaticResource HairlineBrush}" Margin="0,14" />

                <!-- Locations (folders parsed from saved project paths) -->
                <TextBlock Text="LOCATIONS"
                           Style="{StaticResource SectionLabelStyle}"
                           Margin="10,0,10,6" />
                <StackPanel x:Name="LocationsList" Spacing="0" />
            </StackPanel>
        </Border>

        <!-- ── Main area ────────────────────────────────────────────── -->
        <Grid Grid.Column="1">
        <ScrollViewer x:Name="RecentScroll" Padding="56,40,56,60"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="1000" Spacing="40">

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="8">
                        <TextBlock x:Name="TbDateLine"
                                   Text="Today · Welcome back"
                                   FontSize="11" CharacterSpacing="140"
                                   Foreground="{StaticResource TextFaintBrush}" />
                        <TextBlock FontSize="40" FontFamily="{StaticResource SerifFont}"
                                   FontStyle="Italic" FontWeight="Normal"
                                   LineHeight="44"
                                   Foreground="{StaticResource TextPrimaryBrush}">
                            <Run x:Name="GreetingRun" Text="Good day. " /><Run Text="Pick up where you left off," Foreground="{StaticResource TextMutedBrush}" /><LineBreak/>
                            <Run Text="or " Foreground="{StaticResource TextMutedBrush}" /><Run Text="start something new." />
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                VerticalAlignment="Bottom">
                        <Button Content="Open file…" Style="{StaticResource BtapButtonStyle}"
                                Click="OnOpenFile" />
                        <Button Content="＋  New project" Style="{StaticResource PrimaryButtonStyle}"
                                Click="OnNewProject" />
                    </StackPanel>
                </Grid>

                <!-- Templates -->
                <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="START A NEW PROJECT"
                                   Style="{StaticResource SectionLabelStyle}" />
                        <TextBlock x:Name="TbTemplateCount" Grid.Column="1" Text="6 presets"
                                   Style="{StaticResource MonoTextStyle}" />
                    </Grid>
                    <ItemsRepeater x:Name="TemplateList">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="160" MaximumRowsOrColumns="6"
                                              Orientation="Horizontal" MinColumnSpacing="12" MinRowSpacing="12" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:TemplateItem">
                                <Button Click="OnOpenTemplate" Tag="{x:Bind}"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Padding="0" HorizontalContentAlignment="Stretch">
                                    <Border Background="{StaticResource BgSurfaceBrush}"
                                            BorderBrush="{StaticResource HairlineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource RadiusMd}">
                                        <StackPanel>
                                            <Border Height="80" Background="{StaticResource BgPageBrush}"
                                                    BorderBrush="{StaticResource HairlineBrush}"
                                                    BorderThickness="0,0,0,1">
                                                <TextBlock Text="＋" FontSize="22"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextFaintBrush}" />
                                            </Border>
                                            <StackPanel Padding="10,8" Spacing="2">
                                                <TextBlock Text="{x:Bind Name}" FontSize="12"
                                                           FontWeight="Medium"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{x:Bind Sub}"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource TextFaintBrush}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Recent projects -->
                <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <TextBlock Grid.Column="0" Text="RECENT PROJECTS"
                                   Style="{StaticResource SectionLabelStyle}" />
                        <!-- Search -->
                        <Border Grid.Column="1" Margin="0,0,12,0"
                                Background="{StaticResource BgSurfaceBrush}"
                                BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1" CornerRadius="999" Padding="10,4">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextMutedBrush}" />
                                <TextBox x:Name="SearchBox"
                                         PlaceholderText="Search projects"
                                         Width="180" FontSize="11.5"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         TextChanged="OnSearchChanged" />
                            </StackPanel>
                        </Border>
                        <Button Grid.Column="2" Content="Edited ▾"
                                Style="{StaticResource GhostButtonStyle}"
                                FontSize="11" />
                    </Grid>

                    <Border x:Name="EmptyRecentsHint" Visibility="Collapsed"
                            Padding="24,32"
                            Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource HairlineBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusLg}">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <TextBlock Text="No recent projects"
                                       FontSize="14" FontWeight="Medium"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Save a project to see it here, or open one from your filesystem."
                                       FontSize="11.5"
                                       Foreground="{StaticResource TextFaintBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <ItemsRepeater x:Name="RecentsList">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="280" MaximumRowsOrColumns="3"
                                              Orientation="Horizontal" MinColumnSpacing="16" MinRowSpacing="16" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:RecentProject">
                                <Button Click="OnOpenRecentProject" Tag="{x:Bind}"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Padding="0" HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch">
                                    <Border Background="{StaticResource BgSurfaceBrush}"
                                            BorderBrush="{StaticResource HairlineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource RadiusLg}"
                                           >
                                        <Grid RowDefinitions="Auto,Auto">
                                            <Border Grid.Row="0" Height="120"
                                                    CornerRadius="6,6,0,0">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#4D1A3040" Offset="0"/>
                                                        <GradientStop Color="#4D0A1218" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Grid>
                                                    <Image Source="{x:Bind Thumbnail, Mode=OneWay}"
                                                           Stretch="UniformToFill"
                                                           HorizontalAlignment="Stretch"
                                                           VerticalAlignment="Stretch" />
                                                    <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                            Margin="8" Padding="4,2"
                                                            Background="#CC0A1218"
                                                            CornerRadius="3">
                                                        <TextBlock Text="{x:Bind Duration}"
                                                                   FontFamily="{StaticResource MonoFont}"
                                                                   FontSize="10" Foreground="{StaticResource TextDimBrush}" />
                                                    </Border>
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Row="1" Padding="12,10,12,12" Spacing="4">
                                                <TextBlock Text="{x:Bind Name}" FontSize="13"
                                                           FontWeight="Medium"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Grid.Column="0" Text="{x:Bind LastEdited}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource TextFaintBrush}" />
                                                    <TextBlock Grid.Column="1" Text="{x:Bind Spec}"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               FontSize="10"
                                                               Foreground="{StaticResource TextFaintBrush}" />
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Footer -->
                <Border BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,1,0,0"
                        Padding="0,22,0,0">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   FontSize="11" Foreground="{StaticResource TextFaintBrush}">
                            <Run Text="Open-source · GPLv3 · " />
                            <Run Text="better than the alternative"
                                 Foreground="{StaticResource TextMutedBrush}" />
                        </TextBlock>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16">
                            <TextBlock Text="Docs" FontSize="11"
                                       Foreground="{StaticResource TextFaintBrush}" />
                            <TextBlock Text="Community" FontSize="11"
                                       Foreground="{StaticResource TextFaintBrush}" />
                            <TextBlock Text="Contribute on GitHub" FontSize="11"
                                       Foreground="{StaticResource TextFaintBrush}" />
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="SettingsScroll" Padding="56,40,56,60"
                      Visibility="Collapsed"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      HorizontalScrollMode="Auto">
            <controls:SettingsView x:Name="SettingsViewControl"
                                   HorizontalAlignment="Stretch" />
        </ScrollViewer>
        </Grid>
    </Grid>
</Page>
